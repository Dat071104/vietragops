# Ch?n provider: mock (m?c d?nh), ollama, ho?c groq
LLM_PROVIDER=ollama

# C?u hěnh Ollama (n?u důng local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_NUM_CTX=8192

# C?u hěnh Groq (n?u důng cloud LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
