# Provider: mock (default), ollama, or groq.
LLM_PROVIDER=mock

# Ollama settings, only used when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_NUM_CTX=8192

# Groq settings, only used when LLM_PROVIDER=groq.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Docker Compose maps this value to GROQ_API_KEY inside the container.
# Keep it empty unless intentionally testing Groq in Docker.
VIETRAGOPS_DOCKER_GROQ_API_KEY=

# Optional Docker Compose postgres profile; local dev only.
VIETRAGOPS_POSTGRES_PASSWORD=vietragops_local_dev_only

# .env is local-only and ignored. Do not publish command output that may expand
# real provider keys.
